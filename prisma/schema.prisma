  author    String
  category  String   @default("GENERAL") // GENERAL, LEARNING, EXAM, MOTIVATION, FUNNY
  isActive  Boolean  @default(true)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User @relation(fields: [createdBy], references: [id])
}

// ==================== AUDIT LOG MODEL ====================
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  actorName String
  action    String   // CREATE, UPDATE, DELETE, BAN, APPROVE, REJECT, etc.
  entity    String   // User, Course, Exam, etc.
  entityId  String
  details   String?  // JSON string with change details
  ipAddress String?
  createdAt DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity])
  @@index([createdAt])
}

// ==================== PAYMENT MODEL ====================
model Payment {
  id          String   @id @default(cuid())
  userId      String
  courseId    String
  amount      Float
  currency    String   @default("NGN")
  status      String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  provider    String   @default("PAYSTACK")
  reference   String   @unique
  metadata    String?  // JSON string
  refunded    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

   @@index([userId])
   @@index([status])
   @@index([createdAt])
  }

// ==================== BANK TRANSFER MODEL ====================
// Manual bank transfer payments for users without cards

model BankTransfer {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  currency      String   @default("NGN")
  status        String   @default("PENDING") // PENDING, AWAITING_PAYMENT, VERIFIED, REJECTED, EXPIRED
  
  // Bank details
  bankName      String?
  accountNumber String?
  accountName   String?
  
  // Payment reference (user's payment reference)
  paymentRef    String?
  
  // Admin verification
  verifiedAt    DateTime?
  verifiedBy    String?
  rejectionReason String?
  
  // Expiry
  expiresAt     DateTime?
  
  // Links to what they're paying for
  paymentType   String?  // COURSE, SUBSCRIPTION, DONATION
  courseId      String?
  planType      String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@index([paymentRef])
  @@index([expiresAt])
}

// ==================== SUBSCRIPTION TIER MODEL ====================
// Admin-configurable subscription tiers with pricing

model SubscriptionTier {
  id            String   @id @default(cuid())
  key           String   @unique // FREE, STARTER, PRO, SCHOLAR, SCHOLAR_PLUS
  name          String   // "Starter", "Pro", "Scholar"
  displayName   String   // "Starter Plan", "Pro Member", "Scholar"
  description   String?  // Tier description
  
  // Pricing (in NGN)
  monthlyPrice  Float    @default(0)
  quarterlyPrice Float    @default(0)
  annualPrice   Float    @default(0)
  
  // Limits
  maxHearts           Int @default(5)
  maxGroupsCreate     Int @default(1)
  maxGroupsJoin       Int @default(3)
  dailyMessageLimit   Int @default(10)
  aiChatLimitPerDay   Int @default(5)
  
  // Features (JSON array of feature keys included)
  features      String   @default("[]")
  
  // Visual
  color         String   @default("#6B7280") // Badge color
  icon          String   @default("star") // Badge icon
  sortOrder     Int      @default(0)
  
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  subscriptions Subscription[]
  
  @@index([key])
  @@index([isActive])
  @@index([sortOrder])
}

// ==================== FEATURE TIER MODEL ====================
// Controls which tier can access which feature

model FeatureTier {
  id          String   @id @default(cuid())
  featureKey  String   @unique // ADVANCED_ANALYTICS, EXAM_HUB, etc.
  name        String   // Display name
  description String?
  
  // Default minimum tier required (can be overridden per user)
  minTier     String   @default("PRO") // FREE, STARTER, PRO, SCHOLAR, SCHOLAR_PLUS
  
  // Default access state
  isEnabled   Boolean  @default(true)
  
  // Gem cost if applicable (for pay-to-unlock)
  gemCost     Int?     
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  overrides   UserFeatureOverride[]
  
  @@index([featureKey])
  @@index([minTier])
}

// ==================== USER FEATURE OVERRIDE MODEL ====================
// Admin can grant/deny specific features per user

model UserFeatureOverride {
  id          String   @id @default(cuid())
  userId      String
  featureKey  String
  
  access      String   // GRANTED, DENIED
  expiresAt   DateTime?
  reason      String?  // "Holiday special", "Beta tester", etc.
  grantedBy   String   // Admin ID
  createdAt   DateTime @default(now())
  
  featureTier FeatureTier @relation(fields: [featureKey], references: [featureKey])
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, featureKey])
  @@index([userId])
  @@index([featureKey])
}

// ==================== SUBSCRIPTION MODEL ====================
  model Subscription {
     id              String   @id @default(cuid())
     userId          String
     tierKey         String   // References SubscriptionTier.key
     plan            String   // monthly, quarterly, annual
     amount          Float    // Amount paid in NGN
     status          String   @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED
     paystackRef     String?  // Paystack reference
     startsAt        DateTime @default(now())
     expiresAt       DateTime
     cancelledAt     DateTime?
     createdBy       String   // Admin ID if manually assigned
     createdAt       DateTime @default(now())
     updatedAt       DateTime @updatedAt

     user User @relation("UserSubscriptions", fields: [userId], references: [id])
     tier SubscriptionTier @relation(fields: [tierKey], references: [key])

    @@index([userId])
    @@index([status])
    @@index([expiresAt])
    @@index([tierKey])
  }

 // ==================== USER REPORT MODEL ====================
model UserReport {
  id          String    @id @default(cuid())
  reporterId  String
  targetType  String    // USER, CONTENT
  targetId    String
  reason      String
  description String?
  status      String    @default("PENDING") // PENDING, REVIEWED, RESOLVED, DISMISSED
  reviewedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  reporter User @relation(fields: [reporterId], references: [id])

  @@index([reporterId])
  @@index([status])
  @@index([targetType])
}

// ==================== TEACHER MESSAGING MODEL ====================

model TeacherMessage {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  courseId    String?
  subject     String
  content     String
  isRead      Boolean  @default(false)
  senderRole  String   @default("STUDENT") // STUDENT, TEACHER
  createdAt   DateTime @default(now())

  sender    User @relation("SentMessages", fields: [senderId], references: [id])
  recipient User @relation("ReceivedMessages", fields: [recipientId], references: [id])

  @@index([senderId])
  @@index([recipientId])
  @@index([isRead])
}

// ==================== GEM GIFT MODEL ====================

model GemGift {
  id          String   @id @default(uuid())
  senderId    String
  recipientId String
  amount      Int
  message     String?
  createdAt   DateTime @default(now())

  sender    User @relation(fields: [senderId], references: [id], name: "SentGifts")
  recipient User @relation(fields: [recipientId], references: [id], name: "ReceivedGifts")

  @@index([senderId])
  @@index([recipientId])
  @@index([createdAt])
