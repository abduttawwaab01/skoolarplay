# SkoolarPlay Environment Variables Template
# Copy this file to .env and fill in the values

# ===========================================
# DATABASE (Neon PostgreSQL)
# ===========================================
# Get connection string from: https://neon.tech
# Example: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# Your deployment URL (no trailing slash)
NEXTAUTH_URL=https://skoolarplay.vercel.app

# ===========================================
# PAYSTACK (Payments)
# ===========================================
# Get keys from: https://dashboard.paystack.co/settings/developer
# Server-side secret key for API calls
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key

# Public key for frontend (same as above)
NEXT_PUBLIC_PAYSTACK_KEY=pk_live_your_paystack_public_key

# Webhook secret for verifying Paystack webhooks
# Generate from: https://dashboard.paystack.co/settings/webhook
PAYSTACK_WEBHOOK_SECRET=whsec_your_webhook_secret

# Your app URL for payment callbacks
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ===========================================
# AI ASSISTANT (OpenRouter)
# ===========================================
# Get API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# Optional: Set a specific model
OPENROUTER_MODEL=anthropic/claude-3-haiku-20241107

# ===========================================
# PUSH NOTIFICATIONS (Web Push - VAPID)
# ===========================================
# Generate VAPID keys with: npx web-push generate-vapid-keys
# Or visit: https://web-push-book.appspot.com/
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# ===========================================
# UPSTASH REDIS (Rate Limiting)
# ===========================================
# Get free tier from: https://upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# ===========================================
# CRON JOBS (Vercel)
# ===========================================
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ===========================================
# UPSTASH REDIS (Rate Limiting)
# ===========================================
# Get free tier from: https://upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# ===========================================
# CRON JOBS (Vercel)
# ===========================================
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ===========================================
# ADMIN CONFIGURATION
# ===========================================
ADMIN_EMAIL=admin@skoolarplay.com

# ===========================================
# CLOUDFLARE R2 (File Storage)
# ===========================================
# Setup guide: See CLOUDFLARE_R2_SETUP.md
# Get credentials from: https://dash.cloudflare.com/r2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=skoolarplay
R2_PUBLIC_URL=https://{accountId}.r2.cloudflarestorage.com

# ===========================================
# EMAIL SERVICE (Resend)
# ===========================================
# Get API key from: https://resend.com
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ===========================================
# GOOGLE SHEETS (Registration Tracking)
# ===========================================
# Google Apps Script webhook URL for recording new registrations
# Create a Google Sheet, go to Extensions > Apps Script, create a POST handler,
# deploy as Web App, and paste the URL here
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ===========================================
# BANK TRANSFER (Manual Payment Fallback)
# ===========================================
# Bank details for manual bank transfer payments
BANK_NAME=First Bank of Nigeria
BANK_ACCOUNT_NUMBER=3084723948
BANK_ACCOUNT_NAME=SkoolarPlay Ltd
