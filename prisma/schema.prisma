  userId    String
  endpoint  String   // Web push endpoint URL
  keys      String   // JSON: { p256dh, auth }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==================== WAEC/JAMB QUESTIONS MODEL ====================

model WaecQuestion {
  id            String   @id @default(cuid())
  courseId      String?
  lessonId      String?
  topicId       String?
  year          Int?     // Exam year
  questionType  String   @default("MCQ") // MCQ, ESSAY, FILL_BLANK, TRUE_FALSE
  question      String
  options       String?  // JSON string of options array
  correctAnswer String
  explanation   String?
  difficulty    String   @default("HARD") // EASY, MEDIUM, HARD, VERY_HARD
  isPremium     Boolean  @default(true) // WAEC questions are premium-only
  subject       String?  // Mathematics, English, Physics, etc.
  examType      String?  // WAEC, JAMB, NECO
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([subject])
  @@index([examType])
  @@index([year])
  @@index([isPremium])
}

// ==================== INVESTOR/PARTNER MODEL ====================

model InvestorPartner {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?  // URL to partner/investor logo image
  website     String?
  tier        String   @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM
  description String?
  isActive    Boolean  @default(true)
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tier])
  @@index([isActive])
  @@index([displayOrder])
}

 // ==================== SPONSOR MODEL ====================

model Sponsor {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?  // URL to sponsor logo image
  website     String?
  tier        String   @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM, DIAMOND
  description String?
  donatedAmount Float  @default(0) // Amount donated in NGN
  isActive    Boolean  @default(true)
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tier])
  @@index([isActive])
  @@index([displayOrder])
}

// ==================== VOLUNTEER MODEL ====================

model Volunteer {
  id          String   @id @default(cuid())
  name        String
  displayOrder Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([displayOrder])
}

// ==================== DONATION SETTINGS MODEL ====================
// Single record storing platform donation configuration

model DonationSettings {
  id                    String   @id @default(cuid())
  goalAmount            Float    @default(5000000) // Fundraising goal in NGN
  currentAmount         Float    @default(0)       // Current amount raised (auto-updated)
  currency              String   @default("NGN")
  paystackPublicKey     String?  // Public key for donation checkout
  paystackSecretKey     String?  // Encrypted secret key (admin only)
  message               String?  // Hero message/headline
  isActive              Boolean  @default(true)
  updatedAt             DateTime @updatedAt
  updatedBy             String   // Admin user ID who last updated

  @@unique([id])
}

// ==================== DONATION MODEL ====================
// Individual donation transactions

model Donation {
  id                    String   @id @default(cuid())
  donorName             String   // Required (even if anonymous - show "Anonymous")
  donorEmail            String?  // Optional for privacy
  amount                Float    // Amount in NGN (not kobo)
  tier                  String?  // Which tier they selected (Supporter, Champion, etc.)
  message               String?  // Optional message from donor
  isAnonymous           Boolean  @default(false)
  paymentRef            String?  // Paystack reference number
  paymentStatus         String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  provider              String   @default("DIRECT")   // DIRECT, PAYSTACK, BANK_TRANSFER
  metadata              String?  // JSON string for extra data
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([paymentStatus])
  @@index([createdAt])
  @@index([paymentRef])
  @@index([amount])
}

// ==================== DONOR RANKING TIER MODEL ====================
// Configurable tier thresholds for donor recognition

model DonorTier {
  id          String   @id @default(cuid())
  name        String   // e.g., "Bronze", "Silver", "Gold"
  minAmount   Float    // Minimum cumulative donation to qualify (NGN)
  maxAmount   Float?   // Maximum amount (null = no upper limit)
  badgeColor  String   @default("#CD7F32") // Hex color for badge
  badgeIcon   String?  // Optional icon
  isActive    Boolean  @default(true)
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

   @@unique([name])
   @@index([displayOrder])
   @@index([minAmount])
 }

 // ==================== FEED POST MODEL ====================
 // User-generated posts for the community feed

model FeedPost {
   id               String   @id @default(cuid())
   authorId         String
   content          String   // Text content (max 5000 chars)
   visibility       String   @default("PUBLIC") // PUBLIC, FOLLOWERS_ONLY, PRIVATE
   isApproved       Boolean  @default(false) // Admin approval required before visible
   isHidden         Boolean  @default(false) // Soft delete/hide by author or admin
   likeCount        Int      @default(0)
   commentCount     Int      @default(0)
   mediaUrls        String?  // JSON array of media URLs (images, videos)
   mentionedUserIds String?  // JSON array of user IDs mentioned (@mentions)
   createdAt        DateTime @default(now())
   updatedAt        DateTime @updatedAt

    author           User     @relation("FeedAuthor", fields: [authorId], references: [id])
    likes            FeedLike[]
    comments         FeedComment[]
    reports          FeedReport[] @relation("PostReports")

   @@index([authorId])
   @@index([createdAt])
   @@index([isApproved])
   @@index([isHidden])
 }

 // ==================== FEED LIKE MODEL ====================

 model FeedLike {
    id        String   @id @default(cuid())
    postId    String
    userId    String
    type      String   @default("LIKE") // LIKE, LOVE, HAHA, WOW, SAD, ANGRY (emoji reactions)
    createdAt DateTime @default(now())

    post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
    user      User     @relation("UserFeedLikes", fields: [userId], references: [id])

   @@unique([postId, userId])
   @@index([userId])
   @@index([createdAt])
 }

 // ==================== FEED COMMENT MODEL ====================

 model FeedComment {
    id         String   @id @default(cuid())
    postId     String
    userId     String
    parentId   String?  // For threaded comments (replies)
    content    String   // Comment text (max 1000 chars)
    isEdited   Boolean  @default(false)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    post       FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
    user       User     @relation("UserFeedComments", fields: [userId], references: [id])
    parent     FeedComment? @relation("CommentReply", fields: [parentId], references: [id])
    replies    FeedComment[] @relation("CommentReply")

   @@index([postId])
   @@index([userId])
   @@index([createdAt])
   @@index([parentId])
 }

 // ==================== FEED REPORT MODEL ====================

model FeedReport {
   id          String   @id @default(cuid())
   postId      String
   reporterId  String
   reason      String   // SPAM, INAPPROPRIATE, HARASSMENT, FALSE_INFO, OTHER
   description String?  // Detailed explanation
   status      String   @default("PENDING") // PENDING, REVIEWED, RESOLVED, DISMISSED
   reviewedBy  String?  // Admin who reviewed
   resolvedAt  DateTime?
   createdAt   DateTime @default(now())

   post        FeedPost @relation("PostReports", fields: [postId], references: [id])
   reporter    User     @relation("UserFeedReports", fields: [reporterId], references: [id])

    @@unique([postId, reporterId]) // One report per user per post
    @@index([status])
    @@index([createdAt])
  }

  // ==================== SURVEY MODELS ====================

  model Survey {
    id            String   @id @default(cuid())
    title         String
    description   String?
    triggerType   String   @default("COURSE_COMPLETION") // COURSE_COMPLETION, MANUAL, SCHEDULED
    triggerConfig String?  // JSON: { courseId, lessonId, delayDays, etc. }
    isActive      Boolean  @default(true)
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    questions     SurveyQuestion[]
    responses     SurveyResponse[]

    @@index([triggerType])
    @@index([isActive])
    @@index([createdAt])
  }

  model SurveyQuestion {
    id         String   @id @default(cuid())
    surveyId   String
    type       String   // MCQ, TEXT, RATING, YES_NO, MULTIPLE_SELECT, NUMBER
    question   String
    options    String?  // JSON array for MCQ/MULTIPLE_SELECT: ["Option 1", "Option 2"]
    isRequired Boolean  @default(true)
    order      Int      @default(0)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    survey     Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
    responses  SurveyAnswer[]

    @@index([surveyId])
    @@index([order])
  }

  model SurveyResponse {
    id          String   @id @default(cuid())
    surveyId    String
    userId      String
    submittedAt DateTime @default(now())

    survey      Survey   @relation(fields: [surveyId], references: [id])
    user        User     @relation(fields: [userId], references: [id])
    answers     SurveyAnswer[]

    @@unique([surveyId, userId])
    @@index([surveyId])
    @@index([userId])
    @@index([submittedAt])
  }

  model SurveyAnswer {
     id          String   @id @default(cuid())
     responseId  String
     questionId  String
     answer      String   // JSON string for structured answers ( MCQ selected option, rating number, etc.)
     answerText  String?  // Plain text for open-ended answers
     createdAt   DateTime @default(now())

     response    SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
     question    SurveyQuestion @relation(fields: [questionId], references: [id])

     @@unique([responseId, questionId])
     @@index([responseId])
   }

// ==================== VOCABULARY MODELS ====================

model VocabularySet {
  id           String   @id @default(cuid())
  title        String
  description  String?
  categoryId   String?
  language     String   @default("en") // Language code (en, yo, ig, ha, fr, es, etc.)
  difficulty   String   @default("BEGINNER") // BEGINNER, INTERMEDIATE, ADVANCED
  level        String?  // CEFR level: A1, A2, B1, B2, C1, C2
  isActive     Boolean  @default(true)
  isPremium    Boolean  @default(false)
  order        Int      @default(0)
  xpReward     Int      @default(10)
  gemReward    Int      @default(2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  words        VocabularyWord[]
  progress     VocabularyProgress[]
  
  category     VocabularyCategory? @relation(fields: [categoryId], references: [id])

  @@index([isActive])
  @@index([language])
  @@index([difficulty])
  @@index([level])
  @@index([categoryId])
}

model VocabularyCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  language    String   @default("en")
  icon        String?
  color       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sets        VocabularySet[]

  @@index([language])
  @@index([isActive])
}

model VocabularyWord {
  id              String   @id @default(cuid())
  vocabularySetId String
  word            String
  definition      String   // English meaning (word only, not phrase)
  translation    String?  // Native language translation for reference
  partOfSpeech    String?  // noun, verb, adjective, etc.
  pronunciation   String?  // Phonetic spelling
  exampleSentence String?  // Example sentence
  exampleTranslation String? // English translation of example
  synonyms        String?  // JSON array of synonyms
  antonyms        String?  // JSON array of antonyms
  difficulty      String   @default("MEDIUM") // EASY, MEDIUM, HARD
  languageCode   String?  // Language code: yo, ig, ha, sw, fr, en
  audioUrl        String?  // Native speaker recording URL
  ttsUrl         String?  // Text-to-Speech URL fallback
  
  // Activity-specific fields
  scrambledWord  String?  // Pre-scrambled version for assembly activity
  missingLetter   String?  // The missing letter for missing alphabet activity
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vocabularySet   VocabularySet @relation(fields: [vocabularySetId], references: [id], onDelete: Cascade)

  @@index([vocabularySetId])
}

model VocabularyProgress {
  id               String   @id @default(cuid())
  userId           String
  vocabularySetId  String
  wordsCompleted   Int      @default(0)
  correctCount     Int      @default(0)
  totalAttempts    Int      @default(0)
  bestStreak       Int      @default(0)
  currentStreak    Int      @default(0)
  lastPracticedAt  DateTime @default(now())
  completed        Boolean  @default(false)
  completedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User           @relation(fields: [userId], references: [id])
  vocabularySet    VocabularySet  @relation(fields: [vocabularySetId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularySetId])
  @@index([userId])
  @@index([vocabularySetId])
}

// ==================== EMAIL VERIFICATION TOKEN MODEL ====================

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

// ==================== GAME CENTER MODELS ====================

model Game {
  id           String   @id @default(cuid())
  title        String
  description  String?
  type         String   // WORD_MATCH, MATH_CHALLENGE, MEMORY_FLIP, QUIZ_RACE, SPELLING_BEE, WORD_SCRAMBLE, ANAGRAMS, TYPING_RACE
  difficulty   String   @default("EASY") // EASY, MEDIUM, HARD, EXPERT
  courseId     String?  // Optional: link to course for content
  icon         String?  // Lucide icon name
  color        String?  @default("#6B7280")
  xpReward     Int      @default(10)
  gemReward    Int      @default(1)
  timeLimit    Int?     // Seconds per game (null = no limit)
  maxAttempts  Int?     // Daily attempts limit (null = unlimited)
  isActive     Boolean  @default(true)
  minLevel     Int      @default(1)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scores GameScore[]

  @@index([isActive])
  @@index([type])
  @@index([sortOrder])
}

model GameScore {
  id          String   @id @default(cuid())
  userId      String
  gameId      String
  score       Int
  timeSpent   Int      // seconds
  xpEarned    Int      @default(0)
  gemsEarned  Int      @default(0)
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([gameId])
  @@index([score])
}

model GameCenterSettings {
  id                     String   @id @default(cuid())
  minLessonsCompleted    Int      @default(5)
  minTimeSpentMinutes    Int      @default(30)
  enablePremiumBypass   Boolean  @default(true)
  dailyXpCap            Int      @default(100)
  dailyGemCap           Int      @default(50)
  updatedAt              DateTime @updatedAt
}
