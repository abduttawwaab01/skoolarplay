generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USER MODELS ====================

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  password       String
  role           String   @default("STUDENT") // ADMIN, STUDENT, TEACHER, SUPPORT
  avatar         String?
  bio            String?
  gems           Int      @default(50)
  xp             Int      @default(0)
  streak         Int      @default(0)
  longestStreak  Int      @default(0)
  hearts         Int      @default(5)
  maxHearts      Int      @default(5)
  lastHeartRefillAt DateTime @default(now())
  lastHeartLossAt DateTime @default(now()) // Track when heart was last lost (cooldown starts from here)
  level          Int      @default(1)
  isBanned       Boolean  @default(false)
  isPremium      Boolean  @default(false)
  premiumExpiresAt DateTime?
  unlockedFeatures String  @default("[]") // JSON array of premium feature keys
  planTier       String   @default("FREE") // FREE, STARTER, PRO, SCHOLAR, SCHOLAR_PLUS
  gemMultiplier  Float    @default(1.0) // Multiplier for gem earnings (admin can set)
  xpMultiplier Float    @default(1.0) // Multiplier for XP earnings (boosts)
  activeBoosts  String   @default("[]") // JSON array of active boosts: [{type: "XP_BOOST", expiresAt: Date}]
  badgeStyle    String   @default("default") // default, minimal, none
  lastActiveAt   DateTime @default(now())
  league         String   @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM, DIAMOND, SAPPHIRE, RUBY, OBSIDIAN
  totalLessonsCompleted Int @default(0)
  totalCoursesCompleted Int @default(0)
  totalExamsCompleted   Int @default(0)
  weeklyXp       Int      @default(0) // XP earned this week (resets weekly)
  isOnline       Boolean  @default(false)
  isDeleted      Boolean  @default(false) // Soft delete flag
  deletedAt      DateTime? // When account was deleted
  deletedBy      String? // Who deleted the account (admin or self)
  delegatedPermissions String @default("[]") // JSON array of delegated permissions for support agents
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Email verification
  emailVerified         DateTime?
  verificationToken     String?
  verificationTokenExpiry DateTime?
  
  // Notification preferences
  emailNotifications    Boolean  @default(true)
  
  // Supabase Auth
  supabaseId      String?
  referralCode    String?

  enrollments                  Enrollment[]
  lessonProgress               LessonProgress[]
  achievements                 UserAchievement[]
  purchases                    Purchase[]
  dailyChallengeCompletions    DailyChallengeCompletion[]
  leaderboardEntries           LeaderboardEntry[]
  certificates                 Certificate[]
  examAttempts                 ExamAttempt[]
  notifications                Notification[]
  studyGroups                  StudyGroupMember[]
  createdGroups                StudyGroup[]      @relation("GroupCreator")
  teacherProfile               TeacherProfile?
  loginRewards                 LoginReward[]
  spinResults                  SpinResult[]
  questCompletions             QuestCompletion[]
  referralsMade                Referral[]              @relation("Referrer")
  referredBy                   Referral?               @relation("Referred")
  mysteryBoxes                 MysteryBox[]
  bossBattleCompletions        BossBattleCompletion[]
  motivationalQuotes           MotivationalQuote[]
  courseReviews                CourseReview[]            @relation("CourseReviewer")
  teacherCourses               Course[]                  @relation("CourseTeacher")
  groupChallengeCompletions    GroupChallengeCompletion[]
  followers                    Follows[]                 @relation("Following")
  following                    Follows[]                 @relation("Follower")
  sentGifts                    GemGift[]                  @relation("SentGifts")
  receivedGifts                GemGift[]                  @relation("ReceivedGifts")
  sentMessages                TeacherMessage[]           @relation("SentMessages")
  receivedMessages             TeacherMessage[]           @relation("ReceivedMessages")
  auditLogs                    AuditLog[]
   payments                     Payment[]
   reports                      UserReport[]
   pushSubscriptions            PushSubscription[]
   groupMessages                GroupMessage[]
    feedPosts                    FeedPost[]           @relation("FeedAuthor")
    feedLikes                    FeedLike[]           @relation("UserFeedLikes")
    feedComments                 FeedComment[]        @relation("UserFeedComments")
    feedReports                  FeedReport[]         @relation("UserFeedReports")
     subscriptions                Subscription[]       @relation("UserSubscriptions")
     surveyResponses              SurveyResponse[]
      vocabularyProgress           VocabularyProgress[]
      gemTransactions              GemTransaction[]
      dailyTasks                   DailyTask[]
      socialRewards                SocialReward[]
       userBattlePass               UserBattlePass[]
       userFeatureOverrides         UserFeatureOverride[]
       giftCodeRedemptions          GiftCodeRedemption[]
       bankTransfers                BankTransfer[]
       gameScores                  GameScore[]
    }

// ==================== CONTENT MODELS ====================

model Category {
  id          String    @id @default(cuid())
  name        String
  description String?
  icon        String?
  color       String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  courses Course[]
}

model Course {
  id          String    @id @default(cuid())
  title       String
  description String?
  categoryId  String
  icon        String?
  color       String?
  difficulty  String    @default("BEGINNER") // BEGINNER, INTERMEDIATE, ADVANCED
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  price       Float     @default(0) // Price in NGN
  isFree      Boolean   @default(true)
  isPremium   Boolean   @default(false) // Premium-restricted course
  certificationEnabled Boolean @default(false)
  minimumLevel String   @default("A1") // A1, A2, B1, B2, C1, C2
  status      String    @default("PUBLISHED") // DRAFT, PUBLISHED, UNLISTED, UNDER_REVIEW
  teacherId   String?
  cutoffScore Int       @default(70) // Minimum score to pass (admin-adjustable)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category    Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  modules     Module[]
  enrollments Enrollment[]
  studyPathId String?
  studyPath   StudyPath?      @relation(fields: [studyPathId], references: [id])
  teacher     User?           @relation("CourseTeacher", fields: [teacherId], references: [id])
  reviews     CourseReview[]
  payments    Payment[]

  @@index([isActive])
  @@index([categoryId])
  @@index([teacherId])
  @@index([status])
}

model Module {
  id        String   @id @default(cuid())
  title     String
  courseId  String
  order     Int      @default(0)
  isPremium Boolean  @default(false) // Premium-restricted module
  isActive  Boolean  @default(true) // Active/Inactive toggle
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  moduleId    String
  type        String   @default("QUIZ") // QUIZ, VIDEO, READING, MIXED
  order       Int      @default(0)
  xpReward    Int      @default(10)
  gemReward   Int      @default(1)
  isActive    Boolean  @default(true)
  isPremium   Boolean  @default(false) // Premium-restricted lesson
  isLocked    Boolean  @default(false)
  lockReason  String?
  unlockThreshold Int  @default(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module       Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions    Question[]
  videoContent VideoContent[]
  lessonNote   LessonNote?
  storyLesson  StoryLesson?
  progress     LessonProgress[]

  @@index([moduleId])
}

model LessonNote {
  id          String   @id @default(cuid())
  lessonId    String?  @unique // Optional - can be standalone note (unique for one-to-one)
  title       String
  content     String   @db.Text // Rich text content
  audioUrl    String?  // Audio file for TTS or uploaded audio
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  
  // Quiz settings
  hasQuiz     Boolean  @default(false)
  quizTitle   String?
  quizQuestions Json?  // JSON array of quiz questions
  quizPassingScore Int @default(50) // Percentage to pass
  quizTimeLimit Int?   // Time limit in minutes
  // Security features
  quizRequireFullscreen Boolean @default(false)
  quizPreventTabSwitch   Boolean @default(false)
  quizPreventCopyPaste   Boolean @default(false)
  quizShuffleQuestions   Boolean @default(false)
  quizShuffleOptions     Boolean @default(false)
  
  // Quiz progress tracking
  quizAttempts Int      @default(0) // Track number of attempts
  
  // Rewards for video quiz (admin can set based on difficulty)
  quizXpReward  Int     @default(10) // XP reward for passing video quiz
  quizGemReward Int     @default(1)  // Gem reward for passing video quiz
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lesson      Lesson?  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@index([lessonId])
  @@index([isActive])
}

model Question {
  id            String   @id @default(cuid())
  lessonId      String
  type          String   @default("MCQ") // MCQ, FILL_BLANK, DRAG_DROP, MATCHING, TRUE_FALSE, ORDERING, CHECKBOX, SPEECH
  question      String
  hint          String?
  explanation   String?
  options       String?  // JSON string
  correctAnswer String   // JSON string
  language     String?  // Language code for SPEECH questions (yo, ig, ha, sw, en, etc.)
  order         Int      @default(0)
  points        Int      @default(10)
  isActive      Boolean  @default(true) // Active/Inactive toggle
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model VideoContent {
  id        String   @id @default(cuid())
  lessonId  String
  title     String
  url       String
  duration  Int      @default(0)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  quiz   VideoQuiz?

  @@index([lessonId])
}

// ==================== VIDEO QUIZ MODELS ====================

model VideoQuiz {
  id            String   @id @default(cuid())
  videoId      String   @unique
  title        String   @default("Video Quiz")
  passingScore Int      @default(60)
  timeLimit    Int?     // Time limit in minutes
  xpReward     Int      @default(15)
  gemReward    Int      @default(2)
  isActive     Boolean  @default(true)
  
  // Security features
  requireFullscreen   Boolean @default(false)
  preventTabSwitch    Boolean @default(false)
  preventCopyPaste    Boolean @default(false)
  shuffleQuestions    Boolean @default(false)
  shuffleOptions      Boolean @default(false)
  
  // Progress tracking
  attempts     Int      @default(0)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  video        VideoContent          @relation(fields: [videoId], references: [id], onDelete: Cascade)
  questions    VideoQuizQuestion[]
  
  @@index([videoId])
  @@index([isActive])
}

model VideoQuizQuestion {
  id            String   @id @default(cuid())
  videoQuizId  String
  type          String   @default("MCQ") // MCQ, FILL_BLANK, DRAG_DROP, MATCHING, TRUE_FALSE, ORDERING
  question      String
  hint          String?
  explanation   String?
  options       String?  // JSON string
  correctAnswer String   // JSON string
  order         Int      @default(0)
  points        Int      @default(10)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  videoQuiz    VideoQuiz @relation(fields: [videoQuizId], references: [id], onDelete: Cascade)

  @@index([videoQuizId])
  @@index([order])
}

// ==================== VIDEO QUIZ PROGRESS MODEL ====================

model VideoQuizProgress {
  id            String   @id @default(cuid())
  userId        String
  videoId       String
  score         Float?
  attempts      Int      @default(0)
  bestScore     Float?
  completed     Boolean  @default(false)
  completedAt   DateTime?
  lastAttemptAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
}

// ==================== PROGRESS MODELS ====================

model Enrollment {
  id              String    @id @default(cuid())
  userId          String
  courseId        String
  progress        Float     @default(0)
  paymentStatus   String    @default("FREE") // FREE, PAID, PENDING
  paymentAmount   Float?
  paymentRef      String?   // Paystack reference
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  score       Float?
  attempts    Int       @default(0)
  bestScore   Float?
  timeSpent   Int       @default(0) // seconds
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@index([userId])
}

// ==================== GAMIFICATION MODELS ====================

model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String?
  icon        String?
  category    String   @default("GENERAL") // GENERAL, LEARNING, SOCIAL, STREAK, MASTERY
  condition   String?  // JSON describing how to earn
  gemReward   Int      @default(0)
  xpReward    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users UserAchievement[]
  
  @@index([category])
  @@index([isActive])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

model ShopItem {
  id        String   @id @default(cuid())
  title     String
  description String?
  type      String   // POWER_UP, AVATAR, THEME, STREAK_FREEZE, BOOST
  icon      String?
  price     Int
  quantity  Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases Purchase[]
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  quantity  Int      @default(1)
  totalGems Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopItem ShopItem @relation(fields: [itemId], references: [id])
}

// ==================== DAILY CHALLENGE MODELS ====================

model DailyChallenge {
  id        String   @id @default(cuid())
  title     String
  description String?
  type      String   // QUIZ, SPEED, ACCURACY
  xpReward  Int      @default(0)
  gemReward Int      @default(0)
  date      String   // YYYY-MM-DD
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  completions DailyChallengeCompletion[]

  @@index([date])
}

model DailyChallengeCompletion {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  score       Float?
  completedAt DateTime @default(now())

  user            User            @relation(fields: [userId], references: [id])
  dailyChallenge  DailyChallenge  @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeId])
}

// ==================== LEADERBOARD MODEL ====================

model LeaderboardEntry {
  id        String   @id @default(cuid())
  userId    String
  period    String   // DAILY, WEEKLY, ALL_TIME
  xp        Int      @default(0)
  rank      Int      @default(0)
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, period, date])
  @@index([userId])
}

// ==================== CERTIFICATE MODEL ====================

model Certificate {
  id            String   @id @default(cuid())
  userId        String
  courseId      String
  courseName    String
  verificationCode String @unique
  
  // Certificate type based on course content
  type          String   @default("STANDARD") // STANDARD, PREMIUM, VERIFIED
  certificateLevel String @default("basic") // basic, intermediate, premium
  courseType    String   @default("GENERAL") // GENERAL, WAEC, JAMB, NECO, VOCATIONAL, PROFESSIONAL
  
  // Certificate content
  score         Float?
  totalLessons  Int?
  completedLessons Int?
  
  // Grade/performance info
  gradeScore    String?  // e.g., "A1", "B2", "400/400"
  competencyAreas String? // JSON array of skills mastered
  rank          Int?     // Class rank if applicable
  completionTime Int?    // Time spent in minutes
  
  // Design settings
  templateStyle String   @default("standard") // standard, modern, classic, animated
  sealStyle     String   @default("round") // round, badge, stamp, animated
  
  // Issuer info
  issuedBy      String   @default("SkoolarPlay")
  ownerName     String   @default("Odebunmi Tawwab")
  
  // Dates
  earnedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([verificationCode])
  @@index([courseType])
}

// ==================== ADMIN MODELS ====================

model AdminSettings {
  id                  String   @id @default(cuid())
  platformName        String   @default("SkoolarPlay")
  dailyXpGoal         Int      @default(50)
  maxHearts           Int      @default(5)
  heartRefillHours    Int      @default(1)
  gemEarnRate         Float    @default(1.0)
  xpMultiplier        Float    @default(1.0)
  maintenanceMode     Boolean  @default(false)
  allowRegistration   Boolean  @default(true)
  dangerZonePassphrase String?  // Security passphrase for danger zone operations
  defaultCutoffScore   Int      @default(70) // Default cutoff score for new courses
  inactivityReminders  String   @default("[5,10,24,48,168,336]") // JSON array of hours for inactivity push notifications
  refundPolicyDays     Int      @default(7) // Refund policy in days
  teacherRefundEnabled Boolean  @default(true) // Allow teacher course refunds

  // ===== CUSTOM BRANDING =====
  loginPageLogoUrl   String?  // Logo displayed on login/register pages
  navBarLogoUrl      String?  // Logo displayed in navigation bar
  footerLogoUrl      String?  // Logo displayed in footer
  faviconUrl         String?  // Custom favicon URL

  // ===== LESSON ORDER ENFORCEMENT =====
  enforceLessonOrder  Boolean  @default(true) // Lock lessons until previous is passed
  allowLessonSkip     Boolean  @default(false) // Allow premium users to skip (overrides enforceLessonOrder)

  // ===== COMPLETION EXAM FOR CERTIFICATES =====
  requireCompletionExam   Boolean  @default(true) // Require exam pass before certificate
  completionExamPassMark  Int      @default(60) // Minimum score for completion exam
  completionExamAttempts  Int      @default(3) // Max attempts at completion exam

  // ===== AI INTEGRATION SETTINGS =====
  aiEnabled            Boolean  @default(true) // Enable/disable AI assistant
  aiRateLimitPerMinute Int      @default(10) // Max AI messages per minute per user
  aiRateLimitPerDay    Int      @default(100) // Max AI messages per day per user
  aiMaxContextMessages Int      @default(20) // Max conversation context messages
  aiModel              String   @default("default") // AI model to use

  // ===== STAY-FREE-FOREVER CACHE SETTINGS =====
  cacheTTLMinutes      Int      @default(30) // Client-side cache TTL in minutes
  enableOfflineMode    Boolean  @default(true) // Allow offline access to cached content
  batchSyncInterval    Int      @default(5) // Minutes between batch syncs

  // ===== PRELOADER SETTINGS =====
  preloaderDurationSeconds Int   @default(3) // How long the preloader shows (in seconds)

  // ===== EMAIL VERIFICATION SETTINGS =====
  requireEmailVerification Boolean @default(true) // Whether to require email verification
  autoVerifyNewUsers       Boolean @default(false) // Auto-verify new users (bypass email verification)

  // ===== STUDY GROUP SETTINGS =====
  freeMaxGroupsCreate    Int      @default(1)      // Groups free users can create
  freeMaxGroupsJoin      Int      @default(3)      // Groups free users can join
  premiumMaxGroupsCreate Int      @default(999)    // Premium users can create unlimited (999)
  premiumMaxGroupsJoin   Int      @default(999)    // Premium users can join unlimited (999)
  freeGroupCreateEnabled Boolean   @default(true)   // Allow free users to create groups
  defaultGroupMaxMembers Int      @default(50)     // Default max members per group
  
  // ===== GROUP MESSAGE LIMITS =====
  freeDailyMessageLimit  Int      @default(20)     // Daily message limit for free users
  premiumDailyMessageLimit Int    @default(999999) // Unlimited for premium
  groupMessageEnabled   Boolean  @default(true)   // Enable group chat feature

  // ===== LEGAL SETTINGS =====
  termsOfService        String?  @db.Text
  privacyPolicy         String?  @db.Text

  // ===== VIDEO UPLOAD SETTINGS =====
  maxVideoSizeMb         Int      @default(100)    // Max video upload size in MB
  allowedVideoFormats    String   @default("[\"mp4\",\"webm\",\"mov\"]") // Allowed video formats

  // ===== CERTIFICATE SETTINGS =====
  founderName            String   @default("Abdut Tawwab")  // Name on certificate
  founderTitle           String   @default("Founder & CEO") // Title on certificate
  founderSignatureUrl    String?  // Signature image URL
  certificatePlatformUrl String?  // Platform URL for verification
  certificateTemplate    String   @default("standard") // standard, intermediate, premium
  premiumCertificateEnabled Boolean @default(true) // Only premium users can get premium certificates
  premiumCertificateBadge String  @default("PREMIUM") // Badge text for premium certificates
  
  // Certificate course type auto-detection keywords
  waecKeywords         String   @default("[\"WAEC\",\"West African Examination Council\",\"GCE\",\"WASSCE\",\"SSCE\"]")
  jambKeywords         String   @default("[\"JAMB\",\"UTME\",\"Joint Admissions\",\" matriculation\"]")
  necoKeywords         String   @default("[\"NECO\",\"National Examination Council\"]")
  vocationalKeywords   String   @default("[\"Vocational\",\"Trade\",\"Technical\",\"Apprenticeship\"]")
  professionalKeywords String   @default("[\"Professional\",\"Certification\",\"Industry\",\"Corporate\"]")

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model FeatureFlag {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String?
  type        String    @default("INFO") // INFO, WARNING, PROMO
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  scheduledAt DateTime?
  imageUrl    String?             // Banner image URL
  bannerType  String    @default("FEATURE") // FEATURE, COURSE, UPDATE, PROMO
  targetUrl   String?             // Link when banner is clicked
  priority    Int       @default(0)           // Higher = shown first
  dismissedBy String    @default("[]")     // JSON array of userIds who dismissed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([priority])
  @@index([bannerType])
}

// ==================== EXAM MODELS ====================

model Exam {
  id             String        @id @default(cuid())
  title          String
  description    String?
  type           String        // WAEC, NECO, JAMB, MOCK, CUSTOM
  subject        String        // Mathematics, English, Physics, Chemistry, Biology, etc.
  year           Int?          // Year of past paper (e.g., 2024)
  duration       Int           @default(60) // minutes
  totalQuestions Int
  totalMarks     Int           @default(100)
  passingMark    Int           @default(50)
  isActive       Boolean       @default(true)
  isPublished    Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  sections  ExamSection[]
  attempts ExamAttempt[]
}

model ExamSection {
  id          String         @id @default(cuid())
  examId      String
  title       String
  instruction String?
  marks       Int
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  questions ExamQuestion[]
  exam      Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
}

model ExamQuestion {
  id            String      @id @default(cuid())
  sectionId     String
  type          String      @default("MCQ") // MCQ, FILL_BLANK, TRUE_FALSE, ESSAY
  question      String
  options       String?     // JSON array of options
  correctAnswer String      // JSON string
  marks         Int         @default(1)
  explanation   String?
  order         Int         @default(0)
