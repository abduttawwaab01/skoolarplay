// ==================== GEM TRANSACTION MODEL ====================
// Detailed gem history for analytics and transparency

model GemTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // Positive = earned, Negative = spent
  type        String   // EARN, SPEND, BONUS, REFERRAL, EVENT, ACHIEVEMENT, GIFT_SENT, GIFT_RECEIVED
  source      String   // quiz, vocabulary, spin, shop, subscription, gift, achievement, etc.
  description String
  relatedId   String?  // quizId, vocabularySetId, etc.
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([createdAt])
}

// ==================== GIFT CODE MODEL ====================
// Admin-generated gift codes for free upgrades/rewards

model GiftCode {
  id          String   @id @default(cuid())
  code        String   @unique
  tier        String?  // STARTER, PRO, SCHOLAR, SCHOLAR_PLUS (null = any)
  duration    Int      // Months of access
  gems        Int?     // Bonus gems (optional)
  usesTotal   Int      @default(1)
  usesUsed    Int      @default(0)
  expiresAt   DateTime?
  createdBy   String   // Admin ID
  createdAt   DateTime @default(now())
  isActive    Boolean  @default(true)
  
  redemptions GiftCodeRedemption[]

  @@index([code])
  @@index([isActive])
  @@index([expiresAt])
}

model GiftCodeRedemption {
  id            String   @id @default(cuid())
  giftCodeId    String
  userId        String
  redeemedAt    DateTime @default(now())
  
  giftCode      GiftCode @relation(fields: [giftCodeId], references: [id])
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([giftCodeId, userId])
  @@index([userId])
}

// ==================== DAILY TASK MODEL ====================

model DailyTask {
  id          String   @id @default(cuid())
  userId      String
  date        String   // YYYY-MM-DD format
  tasks       String   // JSON: {quiz: bool, vocab: bool, groupMsg: bool, etc.}
  completed   Boolean  @default(false)
  bonusClaimed Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date])
  @@index([userId])
}

// ==================== EVENT BONUS MODEL ====================
