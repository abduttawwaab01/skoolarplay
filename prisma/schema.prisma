  description String?
  startDate   DateTime
  endDate     DateTime
  multiplier  Float    @default(1.0) // 2.0 = double gems
  gemBonus    Int      @default(0)   // Flat bonus for first login
  xpMultiplier Float   @default(1.0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([isActive])
  @@index([startDate, endDate])
